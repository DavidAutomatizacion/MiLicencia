        function captureFingerprintCPMotor() {

            if (window.motorFingerprintReceived && window.motorFingerprint != null) {
                return Promise.resolve(window.motorFingerprint);
            }

            if (typeof window.generateExpectedFingerprintTfb !== 'function') {
                const errorMsg = "generateExpectedFingerprintTfb no está disponible";
                return Promise.reject(new Error(errorMsg));
            }

            return window.generateExpectedFingerprintTfb()
                .then(function (fingerprintMotorData) {
                    window.motorFingerprintReceived = true;
                    window.motorFingerprint = fingerprintMotorData;
                    return fingerprintMotorData;
                })
                .catch(function (err) {
                    window.motorFingerprintReceived = false;
                    window.motorFingerprint = '';
                    console.log("[CP] ERROR generateMotorDeviceData\nerror=" + err);
                    return null;
                });
        }

