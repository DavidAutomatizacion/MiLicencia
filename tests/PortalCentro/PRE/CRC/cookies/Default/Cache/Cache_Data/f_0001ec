            if (persona == 'nat') {
                if ($("#rdUsertype1").is(":checked")) {
                    document.getElementById('rdUsertype0').checked = true;
                    onChangePersona();
                }
            }
            else {
                if ($("#rdUsertype0").is(":checked")) {
                    document.getElementById('rdUsertype1').checked = true;
                    onChangePersona();
                }
            }
