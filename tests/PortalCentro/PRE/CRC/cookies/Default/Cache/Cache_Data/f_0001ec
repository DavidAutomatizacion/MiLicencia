        function redirectToBank(checkFinger) {
            const useTFB = (typeof antiFraudeTFBEnable !== "undefined") && antiFraudeTFBEnable === true && canUseTFB();

            if (!useTFB && checkFinger) {
                var seconds = getFingerprintElapsedSeconds();
                if ((finger == null || finger.length == 0) && seconds < 10) {
                    alert('Por favor espere ' + Math.ceil(10 - seconds).toString() + ' segundos para seguir con la transacción');
                    return;
                }
            }
            const btnSeguir = document.getElementById('btnSeguir');
            btnSeguir.disabled = true;
            btnSeguir.offsetHeight;

            let fingerprintToSend = '';

            if (useTFB) {
                const fpCP = getFingerprintCPMotor() || '';
                fingerprintToSend = fpCP ? JSON.stringify(fpCP) : '';

            } else {
                fingerprintToSend = getFinger() || '';
            }

            if ($("#btnSeguir2").is(":visible")) {
                $("#btnSeguir2").prop("disabled", true);
            }

            if ($("#divProcessingSession").is(":hidden")) {
                $("#movilACHST").hide();
                $("#pageProcessingEF").show();
            }

            $.ajax({
                url: "api/RedirectToBank",
                type: "POST",
                headers: headers,
                contentType: "application/json; charset=utf-8",
                data: JSON.stringify({ 'auth': readCookie('PSEAuth'), 'enc': qs("enc"), 'Fingerprint': fingerprintToSend, 'rdPersona': getPersonType(), 'rdOption': getOption(), 'EMail': getEMail(), 'NIT': $("#PJNIT").val(), 'Answer': $("#QuestionResponse").val(), 'txtNombre': getName(), 'ddTipoIdentificacion': getIdType(), 'txtNumeroIdentificacion': getId(), 'txtDireccion': getAddress(), 'txtNumeroCelular': $("#txtNumeroCelular").val(), 'txtEMail': $("#txtEMail").val(), 'hasAceptedPolicyChange': hasAceptedPolicyChange }),
                dataType: "json",
                success: redirectToBankSuccess,
                error: redirectToBankError
            });
        }

        function getFinger() {
            try {
                if (finger != null)
                    return finger;
                else
                    return '';
            }
            catch (error) {
                console.log(error.message);
                return '';
            }
        }

        function getFingerprintCPMotor() {
            try {
                if (window.motorFingerprintReceived && window.motorFingerprint != null) {
                    return window.motorFingerprint;
                } else {
                    return '';
                }
            } catch (error) {
                console.log(error.message);
                return '';
            }
        }

